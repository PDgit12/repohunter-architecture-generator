# RepoHunter Runtime Configuration
ENVIRONMENT=development
CLOUD_EXPERT_ENDPOINT=http://localhost:8000
USE_CLOUD=true

# Security note: set strong random secrets for any public deployment.
EXPERT_API_KEY=replace_with_strong_random_secret
ARCHITECTURE_API_KEY=replace_with_strong_random_secret
ARCHITECTURE_API_KEYS=key_v1,key_v2

# Distributed limiter (optional). If unset, in-memory limiter is used.
REDIS_URL=
ALLOW_IN_MEMORY_RATE_LIMIT_FALLBACK=true
ARCH_RATE_LIMIT_PER_MIN=20
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
