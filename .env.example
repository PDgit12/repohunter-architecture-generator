# RepoHunter Configuration
# -------------------------

# 🔧 LLM Configuration (For Synthesis)
# To offload work from Mac, use Groq (Fastest) or OpenAI.
# Example: https://api.groq.com/openai/v1/chat/completions
REMOTE_LLM_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=your_api_key_here

# 🔍 GitHub Configuration
# Add multiple tokens separated by commas to bypass rate limits
GITHUB_TOKENS=your_github_token_here

# 🧬 Synthesis Settings
MAX_WORKERS=15
SYNTHESIS_MODEL=llama-3.3-70b-versatile

# 🧪 RepoHunter Specifics
ENVIRONMENT=development
FIREBASE_PROJECT_ID=ai-task-mvp-7729
FIREBASE_SERVICE_ACCOUNT_PATH=service-account.json
CLOUD_EXPERT_ENDPOINT=http://localhost:8000
USE_CLOUD=true
LOCAL_MODEL_NAME=llama3
# Security note: set a strong random key for cloud expert auth.
EXPERT_API_KEY=replace_with_strong_random_secret
# Architecture API key (single) or rotated key set (comma-separated)
ARCHITECTURE_API_KEY=replace_with_strong_random_secret
ARCHITECTURE_API_KEYS=key_v1,key_v2
# Distributed limiter (optional). If unset, in-memory limiter is used.
REDIS_URL=
# In production, set to false if Redis must be mandatory.
ALLOW_IN_MEMORY_RATE_LIMIT_FALLBACK=true
# Per-client requests per minute for architecture endpoint
ARCH_RATE_LIMIT_PER_MIN=20
# Comma-separated CORS origins for local API bridge.
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
